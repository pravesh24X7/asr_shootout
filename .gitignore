# ASR Shootout — .gitignore

# Environment
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Audio files (large)
audio_samples/*.wav
audio_samples/*.mp3
audio_samples/*.m4a
audio_samples/*.ogg
audio_samples/*.flac

# Results (generated)
results/raw_results_*.json
results/per_sample_*.csv
results/summary_*.csv
results/charts/*.png

# Keep ground truth
!audio_samples/ground_truth.csv
!audio_samples/metadata.json

# Notebooks
notebooks/.ipynb_checkpoints/

# MacOS
.DS_Store

# IDE
.vscode/
.idea/
