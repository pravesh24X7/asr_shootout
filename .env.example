# =============================================
# ASR Shootout - Environment Variables
# =============================================
# Copy this file to .env and fill in your keys

# --- Deepgram (Baseline) ---
# Sign up at: https://deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- Groq (for Whisper via Groq API) ---
# Sign up at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- AssemblyAI (optional extra model) ---
# Sign up at: https://www.assemblyai.com
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# --- Sarvam AI (Indian language specialist, optional) ---
# Sign up at: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# --- Audio Settings ---
AUDIO_DIR=./audio_samples
RESULTS_DIR=./results

# --- Benchmark Settings ---
# Which models to run (comma-separated): deepgram, groq_whisper, assemblyai, sarvam
MODELS_TO_RUN=deepgram,groq_whisper,assemblyai

# Deepgram model variant: nova-2, nova, enhanced, base
DEEPGRAM_MODEL=nova-2

# Groq Whisper model: whisper-large-v3, whisper-large-v3-turbo
GROQ_WHISPER_MODEL=whisper-large-v3
